@ProductInventoryAPI_HostAddress = http://localhost:5219

GET {{ProductInventoryAPI_HostAddress}}/weatherforecast/
Accept: application/json

###

# Register a new user
POST {{ProductInventoryAPI_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "email": "test@example.com",
  "password": "password123",
  "role": "Viewer"
}

###

# Login
POST {{ProductInventoryAPI_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "testuser",
  "password": "password123"
}

###

# Get products (requires auth)
GET {{ProductInventoryAPI_HostAddress}}/api/product
Authorization: Bearer YOUR_TOKEN_HERE

###
